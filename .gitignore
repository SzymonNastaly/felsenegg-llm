# =========================
# Python
# =========================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
.venv/
env/
ENV/
.env

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
